{
    "layer": "top",
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 32, // Uncomment to set a custom height
    //"output": "DP-1", // Uncomment to specify a display
    //"width": 1850, // Uncomment to set a custom width

// Configuration - modules-left

    "modules-left": ["sway/workspaces", "sway/window"],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
        	"1": "ŅÅŻ",
        	"2": "ŅÅŖ",
            "3": "ŅÅÄ",
            "4": "ŅÅæ",
            "5": "ŅÅĢ",
            "6": "ŅÅś",
            "7": "ŅÅ£",
            "8": "ŅÅ¤",
            "9": "ŅÅŻ"
        }
    },

    "sway/window": {
        "format": "{}",
        "all-outputs": true, // Active window shows only on active display when commented
        "max-length": 70
    },

// Configuration - modules-center
    
    "modules-center": ["clock"],

"clock": {
    "format": "¾░ģÉ {:%OI:%M %p}",
    "on-click": "kitty -T waybar_calcurse -e calcurse",
    // Uncomment to enable right-click calcurse-caldav sync (you need to set it up in calcurse config)
    //"on-click-right": "notify-send \"Running calcurse-caldav...\" \"$(calcurse-caldav)\"",
    "tooltip-format": "’ü│ {:%A %m/%d}\n\n<tt><small>{calendar}</small></tt>",
    "calendar": {
        "on-scroll": 1,
        "format": {
            "months":     "<span color='#f5e0dc'><b>{}</b></span>",
            "days":       "<span color='#f2cdcd'><b>{}</b></span>",
            "weeks":      "<span color='#94e2d5'><b>W{}</b></span>",
            "weekdays":   "<span color='#fab387'><b>{}</b></span>",
            "today":      "<span color='#f38ba8'><b><u>{}</u></b></span>"
        },
    },
},

// Configuration - modules-right

    "modules-right": ["temperature", "cpu", "memory", "network", "bluetooth", "idle_inhibitor", "custom/power"],
    
"temperature": {
    "critical-threshold": 80,
    "format-critical": "’ŗć {temperatureC}┬░C",
    "format": "’ŗē {temperatureC}┬░C",
    "tooltip-format": " {temperatureC}┬░ Celsius\n{temperatureF}┬░ Fahrenheit\n{temperatureK}┬░ Kelvin",
    "on-click": "kitty -T waybar_btop -e btop"
},

"cpu": {
    "interval": 5,
    "format": "’Æ╝ {usage}%",
    "states": {
        "warning": 70,
        "critical": 90,
    },
	"on-click": "kitty -T waybar_btop -e btop"
},
    
"memory": {
    "interval": 5,
    "format": "Ņ┐ģ {}%",
    "on-click": "kitty -T waybar_btop -e btop", 
    "states": {
        "warning": 70,
        "critical": 90
     },
    "tooltip-format": "   Memory: {total} GiB\n   In use: {used} GiB ({percentage}%)\nAvailable: {avail} GiB\n     Swap: {swapTotal} GiB\n   In use: {swapUsed} GiB ({swapPercentage}%)\nAvailable: {swapAvail} GiB",
},

"network": {
    "format-disabled": "’ü▒ Disabled",
    "format-wifi": "’ć½ {essid}",
    "tooltip-format-wifi": "{bandwidthDownBits:>} ¾░ČĪ {bandwidthUpBits:>} ¾░ČŻ",
    "format-ethernet": "¾░łĆ {ipaddr}/{cidr}",
    "tooltip-format-ethernet": "{bandwidthDownBits:>} ¾░ČĪ {bandwidthUpBits:>} ¾░ČŻ",
    "format-disconnected": "’ü▒ Disconnected",
    "on-click": "kitty -T waybar_nmtui -e nmtui",
    "interval": 2
},

"bluetooth": {
    "format": "¾░é» {status}:{num_connections}",
    "format-on": "¾░é»",
    "format-off": "¾░é▓",
    "format-disabled": "", // an empty format will hide the module
    "format-icons": ["¾░żŠ", "¾░ż┐", "¾░źĆ", "¾░źü", "¾░źé", "¾░źā", "¾░źä", "¾░źģ", "¾░źå", "¾░źł"],
    "tooltip-format": "L¾░ŹĮ: bluetui\nR¾░ŹĮ: bluetoothctl power on/off\nController: {controller_alias}\t{controller_address}\nConnected devices: {num_connections}",
    "tooltip-format-connected": "L¾░ŹĮ: bluetui\nR¾░ŹĮ: bluetoothctl power on/off\nController: {controller_alias}\t{controller_address}\nConnected devices: {num_connections}\nDevice---------------Address------------Battery\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias:<20} {device_address:<18}",
    "tooltip-format-enumerate-connected-battery": "{device_alias:<20.20} {device_address:<18.18} {icon} {device_battery_percentage}%",
    "on-click": "kitty -T waybar_bluetui -e bluetui",
    "on-click-right": "~/.config/sway/scripts/bluetooth_toggle.sh"
},

"idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
        "activated": "’ü« ",
        "deactivated": "’ü« ",
    },
    "max-length": 2,
    "tooltip-format-activated": "Activated",
    "tooltip-format-deactivated": "Deactivated"
},

"custom/power": {
    "format":"ŌÅ╗",
    "on-click": "systemctl poweroff",
    "tooltip-format": "Shutdown"
},
}
