# Apply gtk theming
exec_always ~/.config/sway/scripts/import-gsettings

# Set inner/outer gaps
gaps inner 10
gaps outer 0

# Hide titlebar on windows: 
default_border pixel 2
default_floating_border pixel 2

titlebar_border_thickness 2
titlebar_padding 6 6
title_align center

# Default Font
font pango:FiraCodeNerdFont 10

# Thin borders:
smart_borders off

# Set wallpaper:
exec swaybg -i ~/.config/sway/sextant.png

# Title format for windows
for_window [shell="xdg_shell"] title_format "%title (%app_id)"
for_window [shell="x_wayland"] title_format "%class - %title"

## Window decoration
# class                 border  backgr. text    indicator child_border
client.focused          #89b4fa #45475a #89b4fa #89b4fa   #89b4fa
client.focused_inactive #74c7ec #313244 #bac2de #45475a   #45475a
client.unfocused        #74c7ec #313244 #bac2de #45475a   #45475a
client.urgent           #fab387 #fab387 #313244 #94e2d5   #fab387

#
# Status Bar:
#
# Read `man 5 sway-bar` for more information about this section.
bar {
    swaybar_command waybar
}
